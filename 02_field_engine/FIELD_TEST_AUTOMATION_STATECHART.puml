@startuml
title RAMORGA ENGINE – OBSERVE–REGULATE–CONTINUE Statechart

[*] --> OBSERVE

state OBSERVE {
    [*] --> ReadingState
    ReadingState --> RunningHooks : signals, metrics
    RunningHooks --> [*]
}

OBSERVE --> REGULATE : signals_ready

state REGULATE {
    [*] --> RequestGeometry
    RequestGeometry --> ModulateAmplitude : geometry_reference
    ModulateAmplitude --> [*]
}

REGULATE --> CONTINUE : regulation_result

state CONTINUE {
    [*] --> WriteTelemetry
    WriteTelemetry --> CreateNewState
    CreateNewState --> [*]
}

CONTINUE --> OBSERVE : next_cycle

@enduml
